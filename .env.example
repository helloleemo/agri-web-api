# Database
# Local Postgres (Docker)
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/agri_db

# Supabase Cloud Postgres (recommended for deployment)
# Replace the placeholders with your Supabase DB credentials.
# Keep sslmode=require for cloud connection.
DATABASE_URL=postgresql+psycopg://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_DB_HOST:5432/postgres?sslmode=require

# Auth
JWT_SECRET_KEY=change-this-secret-in-env
ACCESS_TOKEN_EXPIRE_MINUTES=60
EMAIL_VERIFICATION_EXPIRE_MINUTES=1440

# Frontend email verification page
FRONTEND_VERIFY_URL=http://localhost:5173/verify-email

# Outgoing mail
# Gmail example (recommended for development):
MAIL_FROM=gmail@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=gmail@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
SMTP_USE_TLS=true
